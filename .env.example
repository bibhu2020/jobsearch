# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
# SQLite fallback used by Python agents only
DATABASE_PATH=./shared/job_tracker.db

# ── File storage ──────────────────────────────────────────────────────────────
ARTIFACTS_PATH=./artifacts
SEARCH_RESULTS_PATH=./search_results

# ── Gateway (NestJS) ──────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
AGENTS_URL=http://localhost:8000

# ── AI keys (required) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# ── AI provider routing (optional) ───────────────────────────────────────────
# Values: "google" or "openai"
AI_PRIMARY_PROVIDER=google
AI_FALLBACK_PROVIDER=openai
# Model overrides (optional — defaults shown)
GOOGLE_AI_MODEL=gemma-4
OPENAI_MODEL=gpt-4o

# ── GitHub artifact storage ───────────────────────────────────────────────────
# Create a classic PAT at github.com/settings/tokens with 'repo' scope
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_ARTIFACTS_PATH=https://github.com/owner/repo/path
GITHUB_BRANCH=main
