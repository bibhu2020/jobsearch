# ── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── File storage (GitHub repo as artifact store) ─────────────────────────────
# Create a classic PAT at github.com/settings/tokens with 'repo' scope
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_ARTIFACTS_PATH=https://github.com/bibhu2020/media/job_search
GITHUB_BRANCH=main

# ── AI providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Service wiring (set automatically in Docker; only needed for local dev) ───
AGENTS_URL=http://localhost:8000
PORT=3000

# ── Local dev only (fallback when GITHUB_TOKEN is not set) ───────────────────
ARTIFACTS_PATH=./artifacts
SEARCH_RESULTS_PATH=./search_results
